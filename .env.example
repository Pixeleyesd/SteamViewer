# Get one at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=<api_key>

# Any long random string, used to sign session cookies.
# Generate one with: node -e "console. log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=<string>

# The externally reachable https URL of this service.
# Must match what you point your tunnel at.
PUBLIC_URL=https://steamviewer.pixeleyesd.dpdns.org

PORT=8111
